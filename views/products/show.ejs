
<% layout('layouts/boilerplate') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>   <!-- displaying flash  -->
<div class="row">
    <div class="col-lg-6 mt-3">

            <!-- displaying flash -->
             <!-- <div class="mb-3">
                <% if(msg && msg.length){ %>
                    <div class="alert alert-success" role="alert">
                        <strong><%= msg%></strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
             </div> -->



            <div class="card border-0 shadow-sm rounded-4 mx-auto" style="width: 20rem;">
                <img src="<%= foundProduct.img %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h2 class="card-title"><%= foundProduct.name %></h2>
                    <h5 class="card-title text-success">₹ <%= foundProduct.price %></h5>
                    <p class="card-text"><%= foundProduct.desc %></p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="/products" class="btn btn-sm btn-light">Back</a>
                        <% if(currentUser && currentUser.role === 'seller' && foundProduct.author && String(foundProduct.author) === String(currentUser._id)){ %>
                            <a href="/products/<%=foundProduct._id%>/edit" class="btn btn-sm btn-dark">Edit</a>
                        <% } %>
                        <% if(currentUser && currentUser.role === 'buyer'){ %>
                            <form method="POST" action="/user/<%=foundProduct._id%>/add" class="d-inline-block">
                                <button class="btn btn-sm btn-secondary">Add to cart</button>
                            </form>
                            <a href="/user/cart" class="btn btn-sm btn-success">Buy now</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mt-3">
            <% if(currentUser && currentUser.role === 'buyer'){ %>
                <div class="card border-0 shadow-sm rounded-4 p-3">
                <h2 class="h4 mb-3">Add Review</h2>
                <form action="/products/<%=foundProduct._id%>/review" method="POST">
                    <div>
                        <fieldset class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="rating" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="rating" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="rating" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="rating" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="rating" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                    </div>

                    <div>
                        <label class="form-label" for="comment">Comment: </label>
                        <textarea class="form-control" rows="3" name="comment" id="comment" placeholder="Write your review."></textarea>
                    </div>

                    <button type="submit" class="btn btn-sm btn-success mt-3">Add Review</button>
                </form>
                </div>
            <% } %>

            <div class="my-3">
                <% for(let review of foundProduct.reviews){ %>

                    <div class="card mt-3 border-0 shadow-sm rounded-4">
                        <p class="card-title mx-3">
                            <% if(review.createdAt){ %>
                                <%=review.createdAt.toDateString() %>
                            <% } %>
                            
                        </p>
                        <p class="starability-result" data-rating="<%=review.rating %>">
                            Rated: <%=review.rating %> stars
                        </p>
                        <div class="card-body">
                            <p class="card-text"><%=review.comment %></p>
                        </div>
                        
                    </div>
                <% } %>
            </div>
        </div>
</div>
</body>
</html>
