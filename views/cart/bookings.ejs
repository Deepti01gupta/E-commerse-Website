<% layout('layouts/boilerplate') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">📅 My Booked Orders</h2>
                <div>
                    <a href="/user/cart" class="btn btn-outline-primary btn-sm me-2">🛒 My Cart</a>
                    <a href="/user/orders" class="btn btn-outline-secondary btn-sm me-2">📋 My Orders</a>
                    <a href="/products" class="btn btn-outline-success btn-sm">Continue Shopping</a>
                </div>
            </div>

            <% if (bookings.length === 0) { %>
                <div class="alert alert-info text-center py-5">
                    <h5>No booked orders yet</h5>
                    <p>You haven't booked any orders for later.</p>
                    <a href="/products" class="btn btn-primary">Continue Shopping</a>
                </div>
            <% } else { %>
                <div class="row">
                    <% bookings.forEach(booking => { %>
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-header" style="background-color: <%= booking.status === 'pending' ? '#fff3cd' : booking.status === 'confirmed' ? '#cfe2ff' : '#d1e7dd' %>">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">
                                            <%= booking.bookingId %>
                                        </h5>
                                        <span class="badge <%= booking.status === 'pending' ? 'bg-warning' : booking.status === 'confirmed' ? 'bg-info' : booking.status === 'cancelled' ? 'bg-danger' : 'bg-success' %>">
                                            <%= booking.status.toUpperCase() %>
                                        </span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted mb-2">
                                        <small>Booked on: <%= new Date(booking.bookingDate).toLocaleDateString() %></small>
                                    </p>
                                    <p class="text-muted mb-3">
                                        <small>Expected on: <%= new Date(booking.expectedBookingDate).toLocaleDateString() %></small>
                                    </p>

                                    <div class="mb-3">
                                        <h6 class="mb-3">📦 Items Ordered (<%= booking.items.length %>)</h6>
                                        <% booking.items.forEach(item => { %>
                                            <div class="d-flex mb-3 pb-3 border-bottom" style="align-items: flex-start;">
                                                <% if (item.image) { %>
                                                    <img src="<%= item.image %>" alt="<%= item.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px; margin-right: 12px;">
                                                <% } else { %>
                                                    <div style="width: 60px; height: 60px; background-color: #f0f0f0; border-radius: 4px; margin-right: 12px; display: flex; align-items: center; justify-content: center;">
                                                        <small class="text-muted">No Image</small>
                                                    </div>
                                                <% } %>
                                                <div style="flex: 1;">
                                                    <p class="mb-1"><strong><%= item.name %></strong></p>
                                                    <p class="mb-1 text-muted"><small>Price: ₹<%= item.price.toFixed(2) %> × <%= item.quantity %> = <strong>₹<%= (item.price * item.quantity).toFixed(2) %></strong></small></p>
                                                </div>
                                            </div>
                                        <% }); %>
                                    </div>

                                    <hr>

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <strong>Total Amount:</strong>
                                        <h5 class="text-success mb-0">₹<%= booking.pricing.total.toFixed(2) %></h5>
                                    </div>
                                </div>
                                <div class="card-footer bg-light">
                                    <a href="/booking/<%= booking._id %>" class="btn btn-sm btn-info">View Details</a>
                                    <% if (booking.status !== 'cancelled' && booking.status !== 'converted_to_purchase') { %>
                                        <form method="POST" action="/booking/<%= booking._id %>/convert-to-order" style="display: inline;">
                                            <button type="submit" class="btn btn-sm btn-success">Convert to Order</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="alert alert-info">
                <h6 class="alert-heading">ℹ️ About Booked Orders</h6>
                <ul class="mb-0">
                    <li><strong>Pending:</strong> Your booking is awaiting confirmation</li>
                    <li><strong>Confirmed:</strong> Your items are reserved and ready to be purchased</li>
                    <li><strong>Converted to Purchase:</strong> Booking has been converted to an actual order</li>
                    <li><strong>Cancelled:</strong> The booking was cancelled</li>
                </ul>
            </div>
        </div>
    </div>
</div>
