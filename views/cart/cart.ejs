<% layout('layouts/boilerplate') %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">My Cart</h1>
    <a href="/products" class="btn btn-outline-secondary btn-sm">Continue Shopping</a>
</div>

<% if(!user.cart || user.cart.length === 0){ %>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body text-center py-5">
            <h2 class="h5">Your cart is empty</h2>
            <p class="text-muted mb-3">Add products to see them here.</p>
            <a href="/products" class="btn btn-primary btn-sm">Browse Products</a>
        </div>
    </div>
<% } else { %>
    <% let total = 0; %>
    <div class="row g-3">
    <% for(let item of user.cart){ %>
        <% total += item.price; %>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <img src="<%=item.img%>" class="card-img-top" alt="<%=item.name%>" style="height:200px;object-fit:cover;">
                <div class="card-body">
                    <h5 class="card-title"><%=item.name%></h5>
                    <p class="card-text text-success fw-semibold mb-0">₹ <%=item.price%></p>
                </div>
            </div>
        </div>
    <% } %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-1">Total</h2>
                <p class="h5 text-success mb-0">₹ <%= total %></p>
            </div>
            <form action="/checkout" method="POST">
                <button class="btn btn-success">Proceed to Payment</button>
            </form>
        </div>
    </div>
<% } %>