# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://127.0.0.1:27017/shopping-sam-app
NODE_ENV=development
PORT=8080
JWT_SECRET=your-secret-key-here

# ============================================
# EMAIL SERVICE (Nodemailer)
# ============================================
# Options: gmail, sendgrid, smtp
EMAIL_SERVICE=gmail

# Gmail Configuration (if using Gmail)
# 1. Enable 2FA on your Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# SendGrid Configuration (if using SendGrid)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generic SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# ============================================
# SMS SERVICE (Twilio)
# ============================================
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PUSH NOTIFICATIONS (Firebase)
# ============================================
# Download serviceAccountKey.json from Firebase Console:
# Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase Web Config (for React - goes in .env.local for client)
REACT_APP_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxxxxxxxx

# VAPID Key for Web Push
# Generate from Firebase Console > Cloud Messaging > Web Configuration
VAPID_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_VERSION=1.0.0

# ============================================
# SESSION & AUTHENTICATION
# ============================================
SESSION_SECRET=keyboard-cat-secret-change-in-production

# ============================================
# STRIPE (if using payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================
# LOGGING & MONITORING (Optional)
# ============================================
LOG_LEVEL=debug
SENTRY_DSN=

# ============================================
# NOTE: 
# Copy to .env and fill in your actual credentials.
# NEVER commit .env file to git!
# ============================================