# ============================================
# FIREBASE CONFIGURATION FOR REACT (Frontend)
# ============================================
# Copy this to .env.local in your React app root
# These values are PUBLIC (it's safe to expose them)

# Firebase Project Configuration
# Get these from Firebase Console > Project Settings > Your apps > Web
REACT_APP_FIREBASE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-abc123.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-abc123
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-abc123.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789abcdef
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# VAPID Public Key (PUBLIC - Safe to expose)
# Generate from Firebase Console > Cloud Messaging > Web Configuration
REACT_APP_VAPID_PUBLIC_KEY=BI4VCvxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Configuration
REACT_APP_API_URL=http://localhost:8080/api

# App Version
REACT_APP_VERSION=1.0.0

# ============================================
# HOW TO GET THESE VALUES:
# ============================================
# 1. Go to https://console.firebase.google.com
# 2. Select your project (or create new)
# 3. Click "Web" to add web app
# 4. Copy the config object values above
# 5. For VAPID key:
#    - Go to Project Settings
#    - Cloud Messaging tab
#    - Click "Generate Key Pair" under Web Push certificates
# ============================================
